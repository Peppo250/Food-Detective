# 🔬 Food Detective Configuration Template
# Copy this file to '.env' in the same directory to customize settings locally.

# Network configuration for the local FastAPI server
FOOD_DETECTIVE_HOST=127.0.0.1
FOOD_DETECTIVE_PORT=8765

# Local SQLite database cache path
# If not specified, defaults to 'data/ingredients.db' at the project root
# FOOD_DETECTIVE_DB_PATH=C:/path/to/custom/ingredients.db

# Reference child weight in kilograms (used to scale EFSA ADI limits)
FOOD_DETECTIVE_CHILD_WEIGHT=20.0
